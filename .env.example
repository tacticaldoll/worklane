# Copy to `.env` (gitignored) and load it — `set -a; source .env; set +a` — or just
# run `just test-live`, which sets these for you.
#
# These enable the durable-broker tests against the local docker-compose services
# (or any reachable Postgres/Redis). They are LOCAL, NON-SECRET endpoints matching
# docker-compose.yml.
#
# Leave them UNSET to skip those tests: a test whose var is set but whose service
# is unreachable FAILS rather than skips, so only set these when the services are
# actually running.
WORKLANE_POSTGRES_TEST_URL=postgres://worklane:worklane@localhost:55432/worklane
WORKLANE_REDIS_TEST_URL=redis://localhost:56379
